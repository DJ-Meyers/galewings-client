# galewings-api base URL (no trailing slash).
VITE_API_URL=http://localhost:8787

# Clerk publishable key (dev or prod). Required unless VITE_DEV_BYPASS_AUTH=true.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Optional — when true, skip Clerk entirely. The galewings-api must
# run with DEV_BYPASS_AUTH=true for this to work end-to-end.
VITE_DEV_BYPASS_AUTH=false
